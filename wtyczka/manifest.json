{
  "manifest_version": 3,
  "name": "Menedżer Haseł (Projekt IoT)",
  "version": "1.0",
  "description": "Bezpieczny menedżer haseł Zero-Knowledge",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs" 
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}